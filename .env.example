# ─── Meta app (Business type) ────────────────────────────────────────
# App Dashboard → Settings → Basic
META_APP_ID=
# App Secret — needed here for token debug/exchange (GET /debug_token).
# NOTE: the leadgen webhook signature (X-Hub-Signature-256) is verified in
# melia-crm's thin relay route, so the CRM also needs this same App Secret.
META_APP_SECRET=
# Pin the API version explicitly (unversioned = oldest live). Bump ~quarterly.
META_API_VERSION=v25.0

# Assets in your own Business Manager (no App Review needed for own assets)
META_AD_ACCOUNT_ID=act_
META_PAGE_ID=
# Conversions API "dataset" id (Events Manager → Data sources) for quality feedback
META_DATASET_ID=

# ─── Bootstrap tokens (stored ENCRYPTED in meta.oauth_tokens via `fb auth-bootstrap`) ──
# You can paste them here once for bootstrap; auth-bootstrap encrypts them into the DB.
# System User token (non-expiring) — campaigns/creatives/insights.
META_SYSTEM_USER_TOKEN=
# Long-lived Page token (leads_retrieval) — resolve leadgen leads. Server only.
META_PAGE_TOKEN=

# ─── Service secrets (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ──
FB_TOKEN_ENCRYPTION_KEY=
# HMAC shared with the CRM /api/ads/meta/lead-ingest route (any 32+ char random string)
FB_INGEST_HMAC_SECRET=

# ─── Database ────────────────────────────────────────────────────────
# Same Postgres cluster as melia-crm; role fb_svc, owner of schema `meta`,
# read-only on ads_contract views. On the box Postgres is published on loopback.
FB_DATABASE_URL=postgresql+psycopg://fb_svc:CHANGEME@127.0.0.1:5432/melia?options=-csearch_path%3Dmeta%2Cpublic

# Where fb-worker POSTs resolved leads (CRM is the sole writer of public.leads)
CRM_INGEST_URL=https://crm.kvadra.me/api/ads/meta/lead-ingest

# ─── Mutation safety ─────────────────────────────────────────────────
# 0 = mutations refused even with confirm. 1 = allowed (with Telegram approval).
FB_ALLOW_MUTATIONS=0
FB_DRY_RUN_DEFAULT=1

# ─── Local creatives (pipeline A reads from disk — no cloud upload) ───
# Semicolon-separated dirs where melia-montage drops finals / renders.
CREATIVE_SOURCE_DIRS=C:\Users\avshc\OneDrive\Desktop\Melia Reels

# ─── IG auto-boost (worker job ig_boost) ────────────────────────────────
# 1 = every 6 h the worker boosts new IG posts as POST_ENGAGEMENT ads in the
# two permanent MB_BOOST_ENG_* campaigns (ads born PAUSED, auto-activated
# after review; ≤6 active per zone, oldest rotated out). 0 = job is a no-op.
FB_IG_BOOST_ENABLED=0
# Instagram professional-account user id linked to META_PAGE_ID (numeric IG
# User id, not the @username). Empty while boost is enabled = daily warning.
FB_IG_USER_ID=

# ─── Telegram ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_FB_CHAT_ID=

# ─── App ─────────────────────────────────────────────────────────────
FB_LOG_LEVEL=INFO
FB_TIMEZONE=Europe/Podgorica
